// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SubscriptionTier {
  id          String   @id @default(uuid())
  name        String   @unique
  maxStorage  BigInt   // Stored in bytes; use BigInt to avoid overflow for multi-GB limits
  price       Decimal  @db.Decimal(10, 2)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id                   String           @id @default(uuid())
  piUid                String           @unique
  username             String
  // Store only encrypted token material at rest; application code must encrypt/decrypt.
  encryptedAccessToken Bytes?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  tierId               String
  subscriptionTier     SubscriptionTier @relation(fields: [tierId], references: [id])
  deployments          Deployment[]
}

model Deployment {
  id          String   @id @default(uuid())
  appName     String
  ipfsHash    String   @unique
  hostingUrl  String
  fileSize    Int      
  status      String   @default("PENDING") 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}
