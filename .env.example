# Root .env for docker-compose
# Copy this file to .env and fill in your values before running docker-compose.
#
# IMPORTANT: Never commit the .env file — it contains secrets.

# PostgreSQL credentials used by the postgres container and the server
POSTGRES_USER=cherri
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=cherri_hosting

# Pi Network App-Platform API key (required)
PI_API_KEY=your_pi_platform_api_key

# Pinata IPFS credentials — use JWT (preferred) or API key + secret
PINATA_JWT=your_pinata_jwt_token
PINATA_API_KEY=
PINATA_API_SECRET=

# CORS origin for the API server (must match where the frontend is served from)
ALLOWED_ORIGIN=http://localhost:8080

# Vite build-time variables baked into the client bundle
VITE_API_URL=http://localhost:4000
VITE_PI_SANDBOX=false
